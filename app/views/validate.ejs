<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %> - DocuValidate</title>
<link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script id="tailwind-config">
  tailwind.config = {
    theme: {
      extend: {
        colors: {
          "primary": "#003d9b",
          "primary-container": "#0052cc",
          "on-primary": "#ffffff",
          "on-background": "#191c1e",
          "on-surface-variant": "#434654",
          "surface": "#f8f9fb",
          "surface-container-lowest": "#ffffff",
          "outline-variant": "#c3c6d6",
          "secondary": "#4c5f81",
          "error": "#ba1a1a",
          "error-container": "#ffdad6"
        },
        fontFamily: { sans: ["Hanken Grotesk", "sans-serif"] }
      }
    }
  }
</script>
<style>
  .material-symbols-outlined { font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 48; }
  body { font-family: 'Hanken Grotesk', sans-serif; background-color: #f8f9fb; }
</style>
</head>
<body class="bg-surface text-on-background min-h-screen flex flex-col">

<header class="bg-primary py-4 shadow-sm">
  <div class="max-w-3xl mx-auto px-6 flex items-center gap-2">
    <span class="material-symbols-outlined text-on-primary" style="font-variation-settings: 'FILL' 1;">description</span>
    <span class="text-on-primary font-bold text-lg">DocuValidate</span>
    <span class="text-on-primary/70 text-sm">– Verificación de Documento</span>
  </div>
</header>

<main class="flex-1 max-w-2xl w-full mx-auto px-6 py-12">

  <% if (!doc) { %>
  <!-- NOT FOUND -->
  <div class="bg-surface-container-lowest rounded-xl shadow-sm border-2 border-outline-variant text-center py-12 px-6">
    <div class="w-20 h-20 rounded-full bg-secondary/10 flex items-center justify-center mx-auto mb-4">
      <span class="material-symbols-outlined text-secondary text-4xl">help</span>
    </div>
    <h1 class="text-2xl font-bold text-secondary mb-2">Documento no encontrado</h1>
    <p class="text-on-surface-variant mb-4">No existe ningún documento con el folio <strong><%= folio %></strong> en nuestra plataforma.</p>
    <span class="inline-block bg-secondary/10 text-secondary font-semibold text-sm px-4 py-1.5 rounded-full">NO REGISTRADO</span>
  </div>

  <% } else if (doc.status === 'vigente') { %>
  <!-- VIGENTE -->
  <div class="bg-surface-container-lowest rounded-xl shadow-sm border-2 border-green-300 text-center py-12 px-6">
    <div class="w-20 h-20 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-4">
      <span class="material-symbols-outlined text-green-600 text-4xl">verified</span>
    </div>
    <h1 class="text-2xl font-bold text-green-700 mb-2">Documento Vigente</h1>
    <p class="text-on-surface-variant mb-4">Este documento está registrado y se encuentra vigente en la plataforma.</p>
    <span class="inline-block bg-green-100 text-green-700 font-semibold text-sm px-4 py-1.5 rounded-full mb-6">VIGENTE</span>
    <hr class="border-outline-variant mb-6">
    <%- docTable(doc) %>
  </div>

  <% } else if (doc.status === 'revocado') { %>
  <!-- REVOCADO -->
  <div class="bg-surface-container-lowest rounded-xl shadow-sm border-2 border-yellow-300 text-center py-12 px-6">
    <div class="w-20 h-20 rounded-full bg-yellow-100 flex items-center justify-center mx-auto mb-4">
      <span class="material-symbols-outlined text-yellow-600 text-4xl">warning</span>
    </div>
    <h1 class="text-2xl font-bold text-yellow-700 mb-2">Documento Revocado</h1>
    <p class="text-on-surface-variant mb-4">Este documento ha sido <strong>revocado</strong> y ya no tiene validez oficial.</p>
    <span class="inline-block bg-yellow-100 text-yellow-700 font-semibold text-sm px-4 py-1.5 rounded-full mb-6">REVOCADO</span>
    <% if (doc.revoked_reason) { %>
    <div class="bg-yellow-50 border border-yellow-200 text-yellow-800 text-left text-sm rounded-lg p-4 mb-6">
      <strong>Motivo de revocación:</strong> <%= doc.revoked_reason %>
    </div>
    <% } %>
    <hr class="border-outline-variant mb-6">
    <%- docTable(doc) %>
  </div>

  <% } else { %>
  <!-- CANCELADO -->
  <div class="bg-surface-container-lowest rounded-xl shadow-sm border-2 border-error/40 text-center py-12 px-6">
    <div class="w-20 h-20 rounded-full bg-error-container/40 flex items-center justify-center mx-auto mb-4">
      <span class="material-symbols-outlined text-error text-4xl">cancel</span>
    </div>
    <h1 class="text-2xl font-bold text-error mb-2">Documento Cancelado</h1>
    <p class="text-on-surface-variant mb-4">Este documento ha sido <strong>cancelado</strong> y no tiene validez.</p>
    <span class="inline-block bg-error-container/40 text-error font-semibold text-sm px-4 py-1.5 rounded-full mb-6">CANCELADO</span>
    <% if (doc.revoked_reason) { %>
    <div class="bg-error-container/20 border border-error/30 text-error text-left text-sm rounded-lg p-4 mb-6">
      <strong>Motivo de cancelación:</strong> <%= doc.revoked_reason %>
    </div>
    <% } %>
    <hr class="border-outline-variant mb-6">
    <%- docTable(doc) %>
  </div>
  <% } %>

  <p class="text-center text-on-surface-variant text-sm mt-6 flex items-center justify-center gap-1">
    <span class="material-symbols-outlined text-base">lock</span>
    Verificación realizada el <%= new Date().toLocaleString('es-MX') %> · DocuValidate
  </p>
</main>

<%
function docTable(d) {
  const row = (label, value) => `
    <div class="flex justify-between gap-4 py-2 border-b border-outline-variant/50 text-left">
      <span class="text-on-surface-variant text-sm">${label}</span>
      <span class="font-semibold text-sm text-right">${value}</span>
    </div>`;
  return `<div class="text-left">
    ${row('Folio', `<code class="text-primary font-bold">${d.folio}</code>`)}
    ${row('Título', d.title)}
    ${row('Tipo', d.document_type)}
    ${row('Área emisora', d.issuing_area)}
    ${row('Fecha de registro', new Date(d.created_at).toLocaleDateString('es-MX'))}
  </div>`;
}
%>
</body>
</html>
