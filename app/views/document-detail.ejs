<%- include('partials/head') %>
<%- include('partials/navbar') %>

<div class="container py-4" style="max-width:900px">
  <div class="d-flex align-items-center mb-4">
    <a href="/documents" class="btn btn-sm btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
    <div>
      <h4 class="mb-0 fw-bold"><i class="bi bi-file-earmark-text me-2 text-primary"></i><%= doc.title %></h4>
      <small class="text-muted">Folio: <code><%= doc.folio %></code></small>
    </div>
  </div>

  <% if (flash) { %>
  <div class="alert alert-<%= flash.type === 'error' ? 'danger' : 'success' %> alert-dismissible fade show">
    <i class="bi bi-info-circle me-1"></i><%= flash.message %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
  <% } %>

  <div class="row g-4">
    <!-- Document info -->
    <div class="col-md-7">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-header bg-white py-3">
          <h6 class="mb-0 fw-semibold"><i class="bi bi-info-circle me-1 text-primary"></i>Información del documento</h6>
        </div>
        <div class="card-body">
          <table class="table table-sm table-borderless mb-0">
            <tr>
              <th class="text-muted w-40">Estado</th>
              <td>
                <% if(doc.status === 'vigente')   { %><span class="badge bg-success fs-6 px-3">Vigente</span>
                <% } else if(doc.status === 'revocado') { %><span class="badge bg-warning text-dark fs-6 px-3">Revocado</span>
                <% } else { %><span class="badge bg-danger fs-6 px-3">Cancelado</span><% } %>
              </td>
            </tr>
            <tr><th class="text-muted">Folio</th><td><code class="text-primary fw-bold"><%= doc.folio %></code></td></tr>
            <tr><th class="text-muted">Título</th><td><%= doc.title %></td></tr>
            <tr><th class="text-muted">Tipo</th><td><%= doc.document_type %></td></tr>
            <tr><th class="text-muted">Área emisora</th><td><%= doc.issuing_area %></td></tr>
            <tr><th class="text-muted">Registrado por</th><td><%= doc.user_name %></td></tr>
            <tr><th class="text-muted">Fecha registro</th><td><%= new Date(doc.created_at).toLocaleString('es-MX') %></td></tr>
            <% if(doc.revoked_at) { %>
            <tr><th class="text-muted">Fecha de cambio</th><td><%= new Date(doc.revoked_at).toLocaleString('es-MX') %></td></tr>
            <% } %>
            <% if(doc.revoked_reason) { %>
            <tr><th class="text-muted">Motivo</th><td><%= doc.revoked_reason %></td></tr>
            <% } %>
            <tr><th class="text-muted">Posición QR</th><td><span class="badge bg-light text-dark border"><%= doc.qr_position %></span></td></tr>
          </table>
        </div>
      </div>
    </div>

    <!-- QR + actions -->
    <div class="col-md-5">
      <div class="card shadow-sm border-0 mb-3">
        <div class="card-header bg-white py-3">
          <h6 class="mb-0 fw-semibold"><i class="bi bi-qr-code me-1 text-primary"></i>Código QR</h6>
        </div>
        <div class="card-body text-center">
          <img src="/<%= doc.qr_path %>" alt="QR Code" class="img-fluid rounded" style="max-width:180px">
          <div class="mt-3">
            <p class="text-muted small mb-1">URL de validación:</p>
            <div class="input-group input-group-sm">
              <input type="text" class="form-control form-control-sm" id="valUrl" value="<%= baseUrl %>/validate/<%= doc.folio %>" readonly>
              <button class="btn btn-outline-secondary" onclick="copyUrl()"><i class="bi bi-clipboard"></i></button>
            </div>
          </div>
          <a href="/validate/<%= doc.folio %>" target="_blank" class="btn btn-sm btn-outline-primary mt-2 w-100">
            <i class="bi bi-box-arrow-up-right me-1"></i>Abrir página de validación
          </a>
        </div>
      </div>

      <div class="card shadow-sm border-0 mb-3">
        <div class="card-header bg-white py-3">
          <h6 class="mb-0 fw-semibold"><i class="bi bi-download me-1 text-primary"></i>Descargar</h6>
        </div>
        <div class="card-body d-grid gap-2">
          <a href="/documents/<%= doc.folio %>/download/qr" class="btn btn-success">
            <i class="bi bi-file-earmark-check me-1"></i>PDF con código QR
          </a>
          <a href="/documents/<%= doc.folio %>/download/original" class="btn btn-outline-secondary">
            <i class="bi bi-file-earmark me-1"></i>PDF original
          </a>
        </div>
      </div>

      <!-- Change status (only if vigente) -->
      <% if(doc.status === 'vigente') { %>
      <div class="card shadow-sm border-0 border-danger">
        <div class="card-header bg-white py-3">
          <h6 class="mb-0 fw-semibold text-danger"><i class="bi bi-shield-exclamation me-1"></i>Cambiar estado</h6>
        </div>
        <div class="card-body">
          <form action="/documents/<%= doc.folio %>/status" method="POST">
            <div class="mb-2">
              <label class="form-label small fw-semibold">Nuevo estado</label>
              <select class="form-select form-select-sm" name="new_status" required>
                <option value="" disabled selected>Selecciona…</option>
                <option value="revocado">Revocar</option>
                <option value="cancelado">Cancelar</option>
              </select>
            </div>
            <div class="mb-3">
              <label class="form-label small fw-semibold">Motivo (opcional)</label>
              <textarea class="form-control form-control-sm" name="reason" rows="2" maxlength="500" placeholder="Indica el motivo del cambio de estado…"></textarea>
            </div>
            <button type="submit" class="btn btn-danger btn-sm w-100"
              onclick="return confirm('¿Confirmas el cambio de estado? Esta acción no se puede deshacer.')">
              <i class="bi bi-exclamation-triangle me-1"></i>Confirmar cambio de estado
            </button>
          </form>
        </div>
      </div>
      <% } %>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
function copyUrl() {
  const input = document.getElementById('valUrl');
  input.select();
  document.execCommand('copy');
  alert('URL copiada al portapapeles.');
}
</script>
</body></html>
