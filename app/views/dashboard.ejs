<%- include('partials/head') %>
<%- include('partials/navbar') %>

<!-- Main Content Canvas -->
<main class="pt-24 pb-12 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">

  <% if (flash) { %>
  <div class="mb-stack-lg px-stack-lg py-3 rounded-lg font-body-md text-body-md flex items-center justify-between <%= flash.type === 'error' ? 'bg-error-container/30 text-on-error-container' : 'bg-green-100 text-green-800' %>">
    <span><%= flash.message %></span>
  </div>
  <% } %>

  <!-- Header Section -->
  <div class="flex flex-col md:flex-row md:items-center justify-between mb-stack-lg gap-stack-md">
    <div>
      <div class="flex items-center gap-stack-sm mb-1">
        <span class="material-symbols-outlined text-primary">speed</span>
        <h1 class="font-headline-lg text-headline-lg-mobile md:text-headline-lg text-on-background">Panel Principal</h1>
      </div>
      <p class="font-body-md text-body-md text-on-surface-variant">Bienvenido, <%= session.userName %></p>
    </div>
    <a href="/documents/upload" class="flex items-center justify-center gap-2 bg-primary-container text-on-primary px-6 py-2.5 rounded-lg font-label-md text-label-md hover:brightness-110 active:scale-95 transition-all shadow-md">
      <span class="material-symbols-outlined text-lg">upload</span>
      Subir Documento
    </a>
  </div>

  <!-- Summary Grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-gutter mb-stack-lg">
    <div class="bg-surface-container-lowest p-6 rounded-xl shadow-sm border border-transparent hover:border-primary/20 transition-all flex flex-col items-center justify-center text-center group">
      <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
        <span class="material-symbols-outlined text-primary text-2xl">description</span>
      </div>
      <span class="font-headline-lg text-headline-lg text-on-background"><%= stats.total || 0 %></span>
      <span class="font-label-md text-label-md text-on-surface-variant mt-1">Total documentos</span>
    </div>
    <div class="bg-surface-container-lowest p-6 rounded-xl shadow-sm border border-transparent hover:border-green-500/20 transition-all flex flex-col items-center justify-center text-center group">
      <div class="w-12 h-12 rounded-full bg-green-100 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
        <span class="material-symbols-outlined text-green-600 text-2xl" style="font-variation-settings: 'FILL' 1;">check_circle</span>
      </div>
      <span class="font-headline-lg text-headline-lg text-on-background"><%= stats.vigentes || 0 %></span>
      <span class="font-label-md text-label-md text-on-surface-variant mt-1">Vigentes</span>
    </div>
    <div class="bg-surface-container-lowest p-6 rounded-xl shadow-sm border border-transparent hover:border-yellow-500/20 transition-all flex flex-col items-center justify-center text-center group">
      <div class="w-12 h-12 rounded-full bg-yellow-100 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
        <span class="material-symbols-outlined text-yellow-600 text-2xl">warning</span>
      </div>
      <span class="font-headline-lg text-headline-lg text-on-background"><%= stats.revocados || 0 %></span>
      <span class="font-label-md text-label-md text-on-surface-variant mt-1">Revocados</span>
    </div>
    <div class="bg-surface-container-lowest p-6 rounded-xl shadow-sm border border-transparent hover:border-error/20 transition-all flex flex-col items-center justify-center text-center group">
      <div class="w-12 h-12 rounded-full bg-error-container/20 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
        <span class="material-symbols-outlined text-error text-2xl">cancel</span>
      </div>
      <span class="font-headline-lg text-headline-lg text-on-background"><%= stats.cancelados || 0 %></span>
      <span class="font-label-md text-label-md text-on-surface-variant mt-1">Cancelados</span>
    </div>
  </div>

  <!-- Recent Documents Table -->
  <section class="bg-surface-container-lowest rounded-xl shadow-sm overflow-hidden">
    <div class="flex items-center justify-between p-stack-lg border-b border-outline-variant">
      <div class="flex items-center gap-stack-sm">
        <span class="material-symbols-outlined text-primary">history</span>
        <h2 class="font-headline-sm text-headline-sm text-on-surface">Documentos Recientes</h2>
      </div>
      <a href="/documents" class="px-4 py-1.5 border border-primary text-primary rounded-lg font-label-md text-label-md hover:bg-primary/5 transition-colors">
        Ver todos
      </a>
    </div>

    <% if (!recent.length) { %>
    <div class="text-center py-16 text-on-surface-variant">
      <span class="material-symbols-outlined text-5xl block mb-2">inbox</span>
      No hay documentos registrados aún.
    </div>
    <% } else { %>
    <div class="overflow-x-auto custom-scrollbar">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-surface-container-low">
            <th class="px-stack-lg py-4 font-label-md text-label-md text-on-surface-variant uppercase tracking-wider">Folio</th>
            <th class="px-stack-lg py-4 font-label-md text-label-md text-on-surface-variant uppercase tracking-wider">Título</th>
            <th class="px-stack-lg py-4 font-label-md text-label-md text-on-surface-variant uppercase tracking-wider">Tipo</th>
            <th class="px-stack-lg py-4 font-label-md text-label-md text-on-surface-variant uppercase tracking-wider">Área</th>
            <th class="px-stack-lg py-4 font-label-md text-label-md text-on-surface-variant uppercase tracking-wider">Fecha</th>
            <th class="px-stack-lg py-4 font-label-md text-label-md text-on-surface-variant uppercase tracking-wider">Estado</th>
            <th class="px-stack-lg py-4 text-right"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-outline-variant">
          <% recent.forEach(doc => { %>
          <tr class="hover:bg-surface-container-low transition-colors duration-150 group">
            <td class="px-stack-lg py-4 font-body-md text-body-md text-primary font-medium"><%= doc.folio %></td>
            <td class="px-stack-lg py-4 font-body-md text-body-md text-on-surface font-semibold"><%= doc.title %></td>
            <td class="px-stack-lg py-4">
              <span class="bg-surface-container px-3 py-1 rounded-full font-label-md text-label-md text-on-surface-variant"><%= doc.document_type %></span>
            </td>
            <td class="px-stack-lg py-4 font-body-md text-body-md text-on-surface-variant"><%= doc.issuing_area %></td>
            <td class="px-stack-lg py-4 font-body-md text-body-md text-on-surface-variant"><%= new Date(doc.created_at).toLocaleDateString('es-MX') %></td>
            <td class="px-stack-lg py-4"><%- statusPill(doc.status) %></td>
            <td class="px-stack-lg py-4 text-right">
              <a href="/documents/<%= doc.folio %>" class="p-2 text-outline hover:text-primary hover:bg-primary/10 rounded-lg transition-all inline-flex">
                <span class="material-symbols-outlined">visibility</span>
              </a>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </section>
</main>

<!-- Footer -->
<footer class="bg-surface-container py-8 mt-12 border-t border-outline-variant">
  <div class="flex flex-col md:flex-row justify-between items-center px-margin-desktop max-w-container-max mx-auto w-full gap-stack-md">
    <div class="flex flex-col items-center md:items-start gap-stack-sm">
      <span class="font-label-md text-label-md font-bold text-on-surface">DocuValidate</span>
      <span class="font-label-md text-label-md text-secondary">© 2026 DocuValidate. Todos los derechos reservados.</span>
    </div>
  </div>
</footer>

<%
function statusPill(s) {
  const map = {
    vigente:   '<span class="bg-green-100 text-green-700 px-3 py-1 rounded-lg font-label-md text-label-md inline-flex items-center gap-1"><span class="w-1.5 h-1.5 rounded-full bg-green-600"></span>Vigente</span>',
    revocado:  '<span class="bg-yellow-100 text-yellow-700 px-3 py-1 rounded-lg font-label-md text-label-md inline-flex items-center gap-1"><span class="w-1.5 h-1.5 rounded-full bg-yellow-600"></span>Revocado</span>',
    cancelado: '<span class="bg-error-container/30 text-error px-3 py-1 rounded-lg font-label-md text-label-md inline-flex items-center gap-1"><span class="w-1.5 h-1.5 rounded-full bg-error"></span>Cancelado</span>',
  };
  return map[s] || s;
}
%>
</body></html>
