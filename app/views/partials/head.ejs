<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %> - DocuValidate</title>
<link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
<link rel="stylesheet" href="/css/style.css">
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script id="tailwind-config">
  tailwind.config = {
    darkMode: "class",
    theme: {
      extend: {
        colors: {
          "on-primary": "#ffffff",
          "on-background": "#191c1e",
          "primary": "#003d9b",
          "on-secondary": "#ffffff",
          "on-secondary-fixed-variant": "#344768",
          "on-surface-variant": "#434654",
          "surface-dim": "#d9dadc",
          "outline": "#737685",
          "primary-container": "#0052cc",
          "on-primary-container": "#c4d2ff",
          "secondary-container": "#c2d5fd",
          "surface": "#f8f9fb",
          "surface-container": "#edeef0",
          "surface-variant": "#e1e2e4",
          "secondary": "#4c5f81",
          "on-secondary-container": "#495c7e",
          "on-error": "#ffffff",
          "surface-container-low": "#f3f4f6",
          "surface-bright": "#f8f9fb",
          "surface-container-highest": "#e1e2e4",
          "surface-container-lowest": "#ffffff",
          "error": "#ba1a1a",
          "on-surface": "#191c1e",
          "surface-container-high": "#e7e8ea",
          "background": "#f8f9fb",
          "outline-variant": "#c3c6d6",
          "on-error-container": "#93000a",
          "error-container": "#ffdad6",
          "inverse-surface": "#2e3132"
        },
        borderRadius: { DEFAULT: "0.25rem", lg: "0.5rem", xl: "0.75rem", full: "9999px" },
        spacing: {
          "margin-mobile": "16px", "gutter": "24px", "stack-md": "16px",
          "stack-sm": "8px", "stack-lg": "24px", "container-max": "1280px", "margin-desktop": "32px"
        },
        fontFamily: {
          "headline-md": ["Hanken Grotesk"], "body-md": ["Hanken Grotesk"],
          "headline-lg": ["Hanken Grotesk"], "label-md": ["Hanken Grotesk"],
          "headline-sm": ["Hanken Grotesk"], "body-lg": ["Hanken Grotesk"],
          "headline-lg-mobile": ["Hanken Grotesk"]
        },
        fontSize: {
          "headline-md": ["24px", { lineHeight: "32px", fontWeight: "600" }],
          "body-md": ["14px", { lineHeight: "20px", fontWeight: "400" }],
          "headline-lg": ["30px", { lineHeight: "38px", fontWeight: "700" }],
          "label-md": ["12px", { lineHeight: "16px", letterSpacing: "0.5px", fontWeight: "600" }],
          "headline-sm": ["20px", { lineHeight: "28px", fontWeight: "600" }],
          "body-lg": ["16px", { lineHeight: "24px", fontWeight: "400" }],
          "headline-lg-mobile": ["24px", { lineHeight: "32px", fontWeight: "700" }]
        }
      }
    }
  }
</script>
<style>
  .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; vertical-align: middle; }
  body { font-family: 'Hanken Grotesk', sans-serif; background-color: #f8f9fb; }
  .custom-scrollbar::-webkit-scrollbar { width: 6px; height: 6px; }
  .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
  .custom-scrollbar::-webkit-scrollbar-thumb { background: #c3c6d6; border-radius: 10px; }
</style>
</head>
<body class="bg-background text-on-background min-h-screen">
