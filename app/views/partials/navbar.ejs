<% const activeNav = typeof active !== 'undefined' ? active : ''; %>
<header class="bg-surface-container-lowest fixed top-0 w-full z-50 shadow-sm">
  <div class="flex items-center justify-between px-margin-mobile md:px-margin-desktop w-full max-w-container-max mx-auto h-16">
    <div class="flex items-center gap-stack-lg">
      <a href="/dashboard" class="flex items-center gap-stack-sm">
        <span class="material-symbols-outlined text-primary text-3xl" style="font-variation-settings: 'FILL' 1;">description</span>
        <span class="font-headline-md text-headline-md font-bold text-primary hidden sm:inline">DocuValidate</span>
      </a>
      <nav class="hidden md:flex items-center gap-gutter">
        <a href="/dashboard" class="font-label-md text-label-md pb-1 transition-colors duration-200 <%= activeNav === 'dashboard' ? 'text-primary border-b-2 border-primary' : 'text-secondary hover:text-primary' %>">Panel</a>
        <a href="/documents" class="font-label-md text-label-md pb-1 transition-colors duration-200 <%= activeNav === 'documents' ? 'text-primary border-b-2 border-primary' : 'text-secondary hover:text-primary' %>">Documentos</a>
        <a href="/documents/upload" class="font-label-md text-label-md pb-1 transition-colors duration-200 <%= activeNav === 'upload' ? 'text-primary border-b-2 border-primary' : 'text-secondary hover:text-primary' %>">Subir</a>
      </nav>
    </div>
    <div class="flex items-center gap-stack-md">
      <div class="relative" id="userMenuWrapper">
        <button id="userMenuBtn" class="flex items-center gap-stack-sm pl-2 md:border-l border-outline-variant">
          <span class="material-symbols-outlined text-on-surface-variant">account_circle</span>
          <span class="hidden lg:block font-label-md text-label-md text-on-surface"><%= session.userName %></span>
          <span class="material-symbols-outlined text-on-surface-variant text-base">arrow_drop_down</span>
        </button>
        <div id="userMenuDropdown" class="hidden absolute right-0 mt-2 w-44 bg-surface-container-lowest rounded-lg shadow-lg border border-outline-variant overflow-hidden">
          <a href="/logout" class="flex items-center gap-stack-sm px-4 py-2.5 text-error font-body-md text-body-md hover:bg-error-container/20 transition-colors">
            <span class="material-symbols-outlined text-lg">logout</span>Cerrar sesión
          </a>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  (function () {
    const btn = document.getElementById('userMenuBtn');
    const dropdown = document.getElementById('userMenuDropdown');
    if (!btn || !dropdown) return;
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      dropdown.classList.toggle('hidden');
    });
    document.addEventListener('click', () => dropdown.classList.add('hidden'));
  })();
</script>
