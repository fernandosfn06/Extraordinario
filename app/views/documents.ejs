<%- include('partials/head') %>
<%- include('partials/navbar') %>

<div class="container-fluid py-4 px-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h4 class="mb-0 fw-bold"><i class="bi bi-folder2-open me-2 text-primary"></i>Repositorio de Documentos</h4>
      <small class="text-muted"><%= documents.length %> resultado(s)</small>
    </div>
    <a href="/documents/upload" class="btn btn-primary">
      <i class="bi bi-cloud-upload me-1"></i>Subir
    </a>
  </div>

  <% if (flash) { %>
  <div class="alert alert-<%= flash.type === 'error' ? 'danger' : 'success' %> alert-dismissible fade show">
    <%= flash.message %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
  <% } %>

  <!-- Filters -->
  <form method="GET" action="/documents" class="row g-2 mb-3">
    <div class="col-md-6">
      <div class="input-group">
        <span class="input-group-text"><i class="bi bi-search"></i></span>
        <input type="text" class="form-control" name="search" value="<%= search %>" placeholder="Buscar por folio, título o área…">
      </div>
    </div>
    <div class="col-md-3">
      <select class="form-select" name="status">
        <option value="">Todos los estados</option>
        <option value="vigente"   <%= status === 'vigente'   ? 'selected' : '' %>>Vigente</option>
        <option value="revocado"  <%= status === 'revocado'  ? 'selected' : '' %>>Revocado</option>
        <option value="cancelado" <%= status === 'cancelado' ? 'selected' : '' %>>Cancelado</option>
      </select>
    </div>
    <div class="col-auto">
      <button type="submit" class="btn btn-outline-primary"><i class="bi bi-funnel me-1"></i>Filtrar</button>
      <a href="/documents" class="btn btn-outline-secondary ms-1"><i class="bi bi-x-circle"></i></a>
    </div>
  </form>

  <div class="card shadow-sm border-0">
    <div class="card-body p-0">
      <% if (!documents.length) { %>
      <div class="text-center py-5 text-muted">
        <i class="bi bi-inbox fs-1 d-block mb-2"></i>No se encontraron documentos.
      </div>
      <% } else { %>
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Folio</th>
              <th>Título</th>
              <th>Tipo</th>
              <th>Área emisora</th>
              <th>Fecha registro</th>
              <th>Estado</th>
              <th class="text-center">Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% documents.forEach(doc => { %>
            <tr>
              <td><code class="text-primary fw-semibold"><%= doc.folio %></code></td>
              <td class="fw-semibold" style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="<%= doc.title %>"><%= doc.title %></td>
              <td><span class="badge bg-light text-dark border"><%= doc.document_type %></span></td>
              <td><%= doc.issuing_area %></td>
              <td class="text-nowrap"><%= new Date(doc.created_at).toLocaleDateString('es-MX') %></td>
              <td>
                <% if(doc.status === 'vigente')   { %><span class="badge bg-success">Vigente</span>
                <% } else if(doc.status === 'revocado') { %><span class="badge bg-warning text-dark">Revocado</span>
                <% } else { %><span class="badge bg-danger">Cancelado</span><% } %>
              </td>
              <td class="text-center text-nowrap">
                <a href="/documents/<%= doc.folio %>" class="btn btn-sm btn-outline-primary me-1" title="Ver detalle">
                  <i class="bi bi-eye"></i>
                </a>
                <a href="/documents/<%= doc.folio %>/download/qr" class="btn btn-sm btn-outline-success me-1" title="Descargar con QR">
                  <i class="bi bi-download"></i>
                </a>
                <a href="/validate/<%= doc.folio %>" target="_blank" class="btn btn-sm btn-outline-secondary" title="Ver validación pública">
                  <i class="bi bi-qr-code"></i>
                </a>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body></html>
