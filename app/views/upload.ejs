<%- include('partials/head') %>
<%- include('partials/navbar') %>

<div class="container py-4" style="max-width:760px">
  <div class="d-flex align-items-center mb-4">
    <a href="/documents" class="btn btn-sm btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
    <div>
      <h4 class="mb-0 fw-bold"><i class="bi bi-cloud-upload me-2 text-primary"></i>Subir Documento</h4>
      <small class="text-muted">Registra un nuevo PDF y genera su código QR de validación</small>
    </div>
  </div>

  <% if (flash) { %>
  <div class="alert alert-<%= flash.type === 'error' ? 'danger' : 'success' %> alert-dismissible fade show">
    <i class="bi bi-exclamation-circle me-1"></i><%= flash.message %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
  <% } %>

  <form action="/documents/upload" method="POST" enctype="multipart/form-data">
    <div class="card shadow-sm border-0 mb-4">
      <div class="card-header bg-white py-3">
        <h6 class="mb-0 fw-semibold"><i class="bi bi-info-circle me-1 text-primary"></i>Información del documento</h6>
      </div>
      <div class="card-body">
        <div class="mb-3">
          <label class="form-label fw-semibold">Archivo PDF <span class="text-danger">*</span></label>
          <input type="file" class="form-control" name="pdf" accept=".pdf" required id="pdfInput">
          <div class="form-text">Tamaño máximo: 20 MB. Solo archivos PDF.</div>
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Título del documento <span class="text-danger">*</span></label>
          <input type="text" class="form-control" name="title" placeholder="Ej. Contrato de prestación de servicios" required maxlength="255">
        </div>
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label fw-semibold">Tipo de documento <span class="text-danger">*</span></label>
            <select class="form-select" name="document_type" required>
              <option value="" disabled selected>Selecciona un tipo…</option>
              <option>Contrato</option>
              <option>Convenio</option>
              <option>Resolución</option>
              <option>Circular</option>
              <option>Oficio</option>
              <option>Acuerdo</option>
              <option>Manual</option>
              <option>Reglamento</option>
              <option>Dictamen</option>
              <option>Otro</option>
            </select>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold">Área emisora <span class="text-danger">*</span></label>
            <input type="text" class="form-control" name="issuing_area" placeholder="Ej. Dirección General" required maxlength="100">
          </div>
        </div>
      </div>
    </div>

    <!-- QR position selector -->
    <div class="card shadow-sm border-0 mb-4">
      <div class="card-header bg-white py-3">
        <h6 class="mb-0 fw-semibold"><i class="bi bi-qr-code me-1 text-primary"></i>Posición del código QR</h6>
      </div>
      <div class="card-body">
        <div class="qr-position-wrapper">
          <div class="doc-mock">
            <div class="doc-corner corner-tl">
              <input type="radio" name="qr_position" value="top-left" id="pos-tl" class="d-none">
              <label for="pos-tl" class="corner-label" title="Superior izquierda">
                <i class="bi bi-qr-code-scan"></i>
              </label>
            </div>
            <div class="doc-corner corner-tr">
              <input type="radio" name="qr_position" value="top-right" id="pos-tr" class="d-none">
              <label for="pos-tr" class="corner-label" title="Superior derecha">
                <i class="bi bi-qr-code-scan"></i>
              </label>
            </div>
            <div class="doc-center-text text-muted small">
              <i class="bi bi-file-earmark-text fs-3 d-block mb-1"></i>
              Vista previa<br>del documento
            </div>
            <div class="doc-corner corner-bl">
              <input type="radio" name="qr_position" value="bottom-left" id="pos-bl" class="d-none">
              <label for="pos-bl" class="corner-label" title="Inferior izquierda">
                <i class="bi bi-qr-code-scan"></i>
              </label>
            </div>
            <div class="doc-corner corner-br">
              <input type="radio" name="qr_position" value="bottom-right" id="pos-br" class="d-none" checked>
              <label for="pos-br" class="corner-label active" title="Inferior derecha">
                <i class="bi bi-qr-code-scan"></i>
              </label>
            </div>
          </div>
          <div class="mt-3">
            <input type="radio" name="qr_position" value="last-bottom-right" id="pos-lbr" class="form-check-input">
            <label for="pos-lbr" class="form-check-label ms-1">
              <i class="bi bi-file-earmark-arrow-down me-1"></i>Última página – inferior derecha
            </label>
          </div>
        </div>
        <div id="posLabel" class="mt-2 text-primary small fw-semibold">
          Posición seleccionada: <span id="posText">Inferior derecha</span>
        </div>
      </div>
    </div>

    <div class="d-flex gap-2">
      <button type="submit" class="btn btn-primary px-4">
        <i class="bi bi-upload me-1"></i>Registrar documento
      </button>
      <a href="/documents" class="btn btn-outline-secondary">Cancelar</a>
    </div>
  </form>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
const posNames = {
  'top-left':         'Superior izquierda',
  'top-right':        'Superior derecha',
  'bottom-left':      'Inferior izquierda',
  'bottom-right':     'Inferior derecha',
  'last-bottom-right':'Última página – inferior derecha',
};
document.querySelectorAll('input[name="qr_position"]').forEach(r => {
  r.addEventListener('change', () => {
    document.querySelectorAll('.corner-label').forEach(l => l.classList.remove('active'));
    if (r.nextElementSibling) r.nextElementSibling.classList.add('active');
    document.getElementById('posText').textContent = posNames[r.value] || r.value;
  });
});
</script>
</body></html>
