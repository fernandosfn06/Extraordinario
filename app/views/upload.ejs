<%- include('partials/head') %>
<%- include('partials/navbar') %>

<style>
  .qr-preview-container { aspect-ratio: 3 / 4; background: white; border: 1px solid #DFE1E6; border-radius: 8px; position: relative; }
  .qr-spot {
    width: 40px; height: 40px; border: 2px dashed #c3c6d6; border-radius: 4px;
    display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.2s ease;
  }
  .qr-spot.active { border-style: solid; border-color: #003d9b; background-color: #003d9b; color: white; }
  .qr-spot:hover:not(.active) { border-color: #003d9b; background-color: #f0f5ff; }
</style>

<main class="pt-24 pb-12 px-margin-mobile md:px-margin-desktop max-w-[800px] mx-auto">
  <!-- Header Section -->
  <div class="flex items-start gap-stack-md mb-stack-lg">
    <a href="/documents" class="p-2 border border-outline-variant rounded-lg hover:bg-surface-container transition-all active:scale-95">
      <span class="material-symbols-outlined text-secondary">arrow_back</span>
    </a>
    <div>
      <div class="flex items-center gap-stack-sm">
        <span class="material-symbols-outlined text-primary text-[28px]">cloud_upload</span>
        <h1 class="font-headline-lg text-headline-lg text-on-surface">Subir Documento</h1>
      </div>
      <p class="font-body-md text-body-md text-on-surface-variant mt-1">Registra un nuevo PDF y genera su código QR de validación.</p>
    </div>
  </div>

  <% if (flash) { %>
  <div class="mb-stack-lg px-stack-lg py-3 rounded-lg font-body-md text-body-md <%= flash.type === 'error' ? 'bg-error-container/30 text-on-error-container' : 'bg-green-100 text-green-800' %>">
    <%= flash.message %>
  </div>
  <% } %>

  <form action="/documents/upload" method="POST" enctype="multipart/form-data" class="space-y-stack-lg">
    <!-- Section 1: Document Info -->
    <div class="bg-surface-container-lowest rounded-xl shadow-sm overflow-hidden border border-outline-variant/30">
      <div class="px-stack-lg py-4 border-b border-outline-variant flex items-center gap-stack-sm">
        <span class="material-symbols-outlined text-primary text-sm">info</span>
        <h2 class="font-label-md text-label-md uppercase tracking-wider text-secondary">Información del documento</h2>
      </div>
      <div class="p-stack-lg space-y-6">
        <!-- File Selection -->
        <div class="space-y-2">
          <label class="font-label-md text-label-md text-on-surface block">Archivo PDF <span class="text-error">*</span></label>
          <label class="w-full flex flex-col md:flex-row items-center justify-between p-stack-md border-2 border-dashed border-outline-variant rounded-lg hover:border-primary hover:bg-primary/5 transition-all cursor-pointer group">
            <div class="flex items-center gap-stack-md">
              <span class="material-symbols-outlined text-outline group-hover:text-primary">upload_file</span>
              <div class="text-left">
                <span class="font-body-md text-body-md text-on-surface font-semibold">Elegir archivo</span>
                <p id="fileNameText" class="text-[12px] text-on-surface-variant italic">Ningún archivo seleccionado</p>
              </div>
            </div>
            <span class="mt-2 md:mt-0 font-label-md text-label-md text-on-surface-variant italic">Máximo 20 MB. Solo archivos PDF.</span>
            <input type="file" name="pdf" id="pdfInput" accept=".pdf" required class="hidden">
          </label>
        </div>

        <!-- Title -->
        <div class="space-y-2">
          <label class="font-label-md text-label-md text-on-surface block">Título del documento <span class="text-error">*</span></label>
          <input type="text" name="title" maxlength="255" required placeholder="Ej. Contrato de prestación de servicios"
            class="w-full bg-white border border-outline-variant rounded-lg px-4 py-2.5 font-body-md text-body-md focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all">
        </div>

        <!-- Row: Type & Area -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-stack-lg">
          <div class="space-y-2">
            <label class="font-label-md text-label-md text-on-surface block">Tipo de documento <span class="text-error">*</span></label>
            <select name="document_type" required class="w-full bg-white border border-outline-variant rounded-lg px-4 py-2.5 font-body-md text-body-md focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all">
              <option value="" disabled selected>Selecciona un tipo…</option>
              <option>Contrato</option>
              <option>Convenio</option>
              <option>Resolución</option>
              <option>Circular</option>
              <option>Oficio</option>
              <option>Acuerdo</option>
              <option>Manual</option>
              <option>Reglamento</option>
              <option>Dictamen</option>
              <option>Otro</option>
            </select>
          </div>
          <div class="space-y-2">
            <label class="font-label-md text-label-md text-on-surface block">Área emisora <span class="text-error">*</span></label>
            <input type="text" name="issuing_area" maxlength="100" required placeholder="Ej. Dirección General"
              class="w-full bg-white border border-outline-variant rounded-lg px-4 py-2.5 font-body-md text-body-md focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all">
          </div>
        </div>
      </div>
    </div>

    <!-- Section 2: QR Placement -->
    <div class="bg-surface-container-lowest rounded-xl shadow-sm overflow-hidden border border-outline-variant/30">
      <div class="px-stack-lg py-4 border-b border-outline-variant flex items-center gap-stack-sm">
        <span class="material-symbols-outlined text-primary text-sm">qr_code_2</span>
        <h2 class="font-label-md text-label-md uppercase tracking-wider text-secondary">Posición del código QR</h2>
      </div>
      <div class="p-stack-lg flex flex-col md:flex-row gap-stack-lg items-center">
        <!-- Interactive Preview -->
        <div class="qr-preview-container w-64 p-4 flex flex-col items-center justify-center">
          <div class="absolute inset-0 p-4 grid grid-cols-2 grid-rows-2 gap-4">
            <button type="button" class="qr-spot" data-pos="top-left"><span class="material-symbols-outlined text-lg">qr_code</span></button>
            <button type="button" class="qr-spot justify-self-end" data-pos="top-right"><span class="material-symbols-outlined text-lg">qr_code</span></button>
            <button type="button" class="qr-spot self-end" data-pos="bottom-left"><span class="material-symbols-outlined text-lg">qr_code</span></button>
            <button type="button" class="qr-spot self-end justify-self-end active" data-pos="bottom-right"><span class="material-symbols-outlined text-lg">qr_code</span></button>
          </div>
          <div class="text-center opacity-30 select-none">
            <span class="material-symbols-outlined text-6xl">description</span>
            <p class="font-label-md text-label-md mt-2">Vista previa del documento</p>
          </div>
        </div>

        <!-- Controls -->
        <div class="flex-1 space-y-stack-md">
          <div class="p-stack-md bg-surface-container-low rounded-lg border border-outline-variant/20">
            <div class="flex items-center gap-stack-sm mb-stack-sm">
              <span class="material-symbols-outlined text-primary">auto_stories</span>
              <span class="font-body-md text-body-md font-semibold">Página destino</span>
            </div>
            <label class="flex items-center gap-stack-sm cursor-pointer">
              <input type="checkbox" id="lastPageCheck" class="text-primary focus:ring-primary h-4 w-4 rounded">
              <span class="font-body-md text-body-md text-on-surface">Usar la última página (solo disponible con esquina inferior derecha)</span>
            </label>
          </div>
          <div class="flex items-center gap-stack-sm text-primary">
            <span class="material-symbols-outlined text-[18px]">check_circle</span>
            <span class="font-body-md text-body-md">Posición seleccionada: <strong id="posText">Inferior derecha</strong></span>
          </div>
          <p class="font-label-md text-label-md text-on-surface-variant leading-relaxed">
            El código QR se incrustará digitalmente en el archivo PDF, permitiendo su validación pública al escanearlo.
          </p>
        </div>
      </div>
      <input type="hidden" name="qr_position" id="qrPositionInput" value="bottom-right">
    </div>

    <!-- Footer Actions -->
    <div class="flex flex-col sm:flex-row items-center justify-end gap-stack-md pt-stack-sm pb-stack-lg">
      <a href="/documents" class="w-full sm:w-auto text-center px-stack-lg py-3 rounded-lg border border-outline-variant font-label-md text-label-md font-semibold text-secondary hover:bg-surface-container transition-all active:scale-95">
        Cancelar
      </a>
      <button type="submit" class="w-full sm:w-auto px-stack-lg py-3 rounded-lg bg-primary-container text-on-primary shadow-md hover:shadow-lg transition-all active:scale-95 flex items-center justify-center gap-stack-sm font-label-md text-label-md font-bold uppercase tracking-wide">
        <span class="material-symbols-outlined">save</span>
        Registrar documento
      </button>
    </div>
  </form>
</main>

<footer class="bg-surface-container mt-auto border-t border-outline-variant">
  <div class="flex flex-col md:flex-row justify-between items-center px-margin-desktop max-w-container-max mx-auto w-full py-8">
    <span class="font-label-md text-label-md text-secondary">© 2026 DocuValidate. Todos los derechos reservados.</span>
  </div>
</footer>

<script>
  const spots = document.querySelectorAll('.qr-spot');
  const posText = document.getElementById('posText');
  const lastPageCheck = document.getElementById('lastPageCheck');
  const qrPositionInput = document.getElementById('qrPositionInput');

  const posLabels = {
    'top-left': 'Superior izquierda',
    'top-right': 'Superior derecha',
    'bottom-left': 'Inferior izquierda',
    'bottom-right': 'Inferior derecha',
  };

  let currentCorner = 'bottom-right';

  function updatePosition() {
    if (lastPageCheck.checked && currentCorner === 'bottom-right') {
      qrPositionInput.value = 'last-bottom-right';
      posText.textContent = 'Última página – inferior derecha';
    } else {
      qrPositionInput.value = currentCorner;
      posText.textContent = posLabels[currentCorner];
    }
  }

  spots.forEach(spot => {
    spot.addEventListener('click', () => {
      spots.forEach(s => s.classList.remove('active'));
      spot.classList.add('active');
      currentCorner = spot.getAttribute('data-pos');
      if (currentCorner !== 'bottom-right') {
        lastPageCheck.checked = false;
      }
      updatePosition();
    });
  });

  lastPageCheck.addEventListener('change', () => {
    if (lastPageCheck.checked) {
      spots.forEach(s => s.classList.remove('active'));
      document.querySelector('[data-pos="bottom-right"]').classList.add('active');
      currentCorner = 'bottom-right';
    }
    updatePosition();
  });

  const pdfInput = document.getElementById('pdfInput');
  const fileNameText = document.getElementById('fileNameText');
  pdfInput.addEventListener('change', (e) => {
    if (e.target.files.length > 0) {
      fileNameText.textContent = e.target.files[0].name;
      fileNameText.classList.remove('italic');
      fileNameText.classList.add('font-bold', 'text-primary');
    }
  });
</script>
</body></html>
